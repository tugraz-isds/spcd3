{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "pretty": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "types",
    "allowJs": true,
    "paths": {
      "pc-lib": ["./src/lib/index.ts"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
